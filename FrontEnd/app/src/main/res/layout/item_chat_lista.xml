<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <!-- Icono de chat -->
    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="#E8F0FE"
        android:gravity="center"
        android:layout_marginEnd="14dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💬"
            android:textSize="22sp"/>
    </LinearLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvChatObjeto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#1A1A2E"
            android:fontFamily="@font/poppins_medium"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvChatNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#666666"
            android:fontFamily="@font/poppins_light"/>

        <TextView
            android:id="@+id/tvUltimoMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#999999"
            android:fontFamily="@font/poppins_light"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvChatEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Derecha: badge + flecha -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginStart="8dp">

        <!-- Badge de no leídos -->
        <TextView
            android:id="@+id/tvBadgeNoLeidos"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/badge_rojo"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <!-- Flecha -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="24sp"
            android:textColor="#134299"/>
    </LinearLayout>

</LinearLayout>