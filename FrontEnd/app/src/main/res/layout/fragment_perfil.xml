<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollPerfil"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_perfil_azul">

    <LinearLayout
        android:id="@+id/lyPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mi Perfil"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:fontFamily="@font/poppins_bold"
            android:textSize="28sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <!-- HEADER centrado -->

        <!-- TARJETA: Información personal -->

        <LinearLayout
            android:id="@+id/lyHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="12dp">

            <!-- Foto con marco circular -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:src="@drawable/profileuser"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.ExtraExtraLarge" />

            <!-- Nombre -->
            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Región -->
            <TextView
                android:id="@+id/tvRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:alpha="0.9"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <!-- Reputación estilo chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipReputacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="⭐ 4.5"
                android:textColor="#1D1D1F"
                app:chipBackgroundColor="@android:color/white"
                app:chipCornerRadius="18dp"
                app:chipStrokeColor="#E0E0E0"
                app:chipStrokeWidth="1dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInfoPersonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información personal"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#1D1D1F"
                    android:fontFamily="@font/poppins_bold"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />

                <!-- Teléfono -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teléfono"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#6B6B6B"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:id="@+id/tvTelefono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="55 0000 0000"
                    android:textSize="14sp"
                    android:textColor="#1D1D1F"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="10dp"/>

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#6B6B6B"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="julieG@gmail.com"
                    android:textSize="14sp"
                    android:textColor="#1D1D1F"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="10dp"/>

                <!-- Contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contraseña"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#6B6B6B"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:id="@+id/tvPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="********"
                    android:textSize="14sp"
                    android:textColor="#1D1D1F"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="14dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditarPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Editar perfil"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/poppins_bold"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#1E88E5"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TARJETA: Historial + lista horizontal -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTituloHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Historial de objetos"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#1D1D1F"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Últimos rentados"
                    android:textSize="12sp"
                    android:textColor="#6B6B6B"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:overScrollMode="never"
                    android:clipToPadding="false"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp" />
                <!-- Agregar este TextView justo debajo o cerca del RecyclerView del historial -->
                <TextView
                    android:id="@+id/tvSinHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📦 Sin historial, ¡comienza rentando objetos!"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:textAlignment="center"
                    android:fontFamily="@font/poppins_regular"
                    android:padding="24dp"
                    android:visibility="gone"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp" />
        <View
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <!-- TARJETA: Estadísticas -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEstadisticas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mis estadísticas"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="#134299"
                    android:layout_marginBottom="12dp"/>

                <!-- Fila 1: Tarjetas de resumen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Objetos publicados -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:id="@+id/tvStatPublicados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="#134299"
                            android:fontFamily="@font/poppins_bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Publicados"
                            android:textSize="11sp"
                            android:textColor="#666"
                            android:fontFamily="@font/poppins_regular"/>
                    </LinearLayout>

                    <!-- Objetos rentados -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:id="@+id/tvStatRentados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="#F57C00"
                            android:fontFamily="@font/poppins_bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rentados"
                            android:textSize="11sp"
                            android:textColor="#666"
                            android:fontFamily="@font/poppins_regular"/>
                    </LinearLayout>

                    <!-- Calificación -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="10dp">
                        <TextView
                            android:id="@+id/tvStatCalif"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="22sp"
                            android:textColor="#FFB300"
                            android:fontFamily="@font/poppins_bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Promedio"
                            android:textSize="11sp"
                            android:textColor="#666"
                            android:fontFamily="@font/poppins_regular"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Fila 2: Dinero -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:id="@+id/tvStatGanado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0"
                            android:textSize="18sp"
                            android:textColor="#2E7D32"
                            android:fontFamily="@font/poppins_bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ganado"
                            android:textSize="11sp"
                            android:textColor="#666"
                            android:fontFamily="@font/poppins_regular"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_card"
                        android:padding="10dp">
                        <TextView
                            android:id="@+id/tvStatGastado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0"
                            android:textSize="18sp"
                            android:textColor="#C62828"
                            android:fontFamily="@font/poppins_bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gastado"
                            android:textSize="11sp"
                            android:textColor="#666"
                            android:fontFamily="@font/poppins_regular"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Gráfica de barras: solicitudes por estado -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solicitudes por estado"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="#444"
                    android:layout_marginBottom="8dp"/>

                <!-- Barra: Pendientes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Pendiente"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                    <View
                        android:id="@+id/barPendiente"
                        android:layout_width="0dp"
                        android:layout_height="16dp"
                        android:layout_weight="0"
                        android:background="#FF9800"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/tvBarPendiente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                </LinearLayout>

                <!-- Barra: Aprobadas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Aprobada"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                    <View
                        android:id="@+id/barAprobada"
                        android:layout_width="0dp"
                        android:layout_height="16dp"
                        android:layout_weight="0"
                        android:background="#4CAF50"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/tvBarAprobada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                </LinearLayout>

                <!-- Barra: Pagadas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Pagada"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                    <View
                        android:id="@+id/barPagada"
                        android:layout_width="0dp"
                        android:layout_height="16dp"
                        android:layout_weight="0"
                        android:background="#134299"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/tvBarPagada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                </LinearLayout>

                <!-- Barra: Rechazadas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Rechazada"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                    <View
                        android:id="@+id/barRechazada"
                        android:layout_width="0dp"
                        android:layout_height="16dp"
                        android:layout_weight="0"
                        android:background="#F44336"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/tvBarRechazada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="11sp"
                        android:textColor="#666"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Cerrar sesión"
            android:textColor="@color/white"
            android:backgroundTint="#E91E1E"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_logout"
            app:iconGravity="textStart"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
